#!/bin/bash
## xyloTermux greeting script
## ~/.scripts/xylo-greeting

# Colors
CYAN='\033[38;2;125;207;255m'
PURPLE='\033[38;2;187;154;247m'
GREEN='\033[38;2;158;206;106m'
YELLOW='\033[38;2;224;175;104m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# Time-based greeting
hour=$(date +%H)
if [[ $hour -lt 12 ]]; then
  greet="Good morning"
  icon="ůįĖ®"
elif [[ $hour -lt 18 ]]; then
  greet="Good afternoon"
  icon="ůįĖô"
else
  greet="Good evening"
  icon="ůįĖĒ"
fi

# Battery
bat_info=$(termux-battery-status 2>/dev/null)
if [[ -n "$bat_info" ]]; then
  bat_pct=$(echo "$bat_info" | python3 -c "import sys,json; b=json.load(sys.stdin); print(b['percentage'])" 2>/dev/null)
  bat_status=$(echo "$bat_info" | python3 -c "import sys,json; b=json.load(sys.stdin); print(b['status'])" 2>/dev/null)
  bat_str="${GREEN}${bat_pct}%%${RESET}"
  [[ "$bat_status" == "CHARGING" ]] && bat_str="${YELLOW}${bat_pct}%% ‚ö°${RESET}"
else
  bat_str="${DIM}n/a${RESET}"
fi

# Storage
storage=$(df -h /data 2>/dev/null | awk 'NR==2{print $4}')

# Network
wifi=$(termux-wifi-connectioninfo 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('ssid','N/A'))" 2>/dev/null || echo "N/A")

echo ""
echo -e "  ${PURPLE}${BOLD}‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ${RESET}"
echo -e "  ${PURPLE}‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó${RESET}"
echo -e "  ${CYAN} ‚ēö‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ${RESET}"
echo -e "  ${CYAN} ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó   ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ${RESET}"
echo -e "  ${PURPLE}‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ${RESET}"
echo -e "  ${PURPLE}‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ${RESET}"
echo ""
echo -e "  ${DIM}your terminal. your rules.${RESET}"
echo ""
echo -e "  ${PURPLE}${icon} ${greet}!${RESET}"
echo -e "  ${DIM}$(date '+%A, %d %B %Y  %H:%M')${RESET}"
echo ""
echo -e "  ůįĀĻ  Battery  ${bat_str}   ůįčä  Free  ${GREEN}${storage}${RESET}   ůį§®  ${GREEN}${wifi}${RESET}"
echo ""
echo -e "  ${DIM}Type ${RESET}${CYAN}help${RESET}${DIM} for xylo commands${RESET}"
echo ""
